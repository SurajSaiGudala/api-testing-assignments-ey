{
  "info": {
    "name": "API Test Template - Generated",
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "description": "Postman collection template generated from a natural-language prompt. Import and customize the request URLs/variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Post (example)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Sample title\",\n  \"body\": \"Sample body\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Validate response status and headers",
              "pm.test('Status code is 201 or 200', function () {",
              "    pm.expect(pm.response.code === 201 || pm.response.code === 200).to.be.true;",
              "});",
              "pm.test('Response has JSON content-type', function () {",
              "    pm.expect(pm.response.headers.get('content-type')).to.include('application/json');",
              "});",
              "// Validate body and copy values into environment for later requests",
              "pm.test('Response contains id and echoed fields', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.expect(json).to.have.property('title');",
              "    pm.expect(json).to.have.property('body');",
              "    pm.expect(json).to.have.property('userId');",
              "    pm.expect(json.title).to.eql('Sample title');",
              "    pm.expect(json.body).to.eql('Sample body');",
              "    pm.expect(json.userId).to.eql(1);",
              "    // store created id for subsequent requests",
              "    pm.environment.set('createdId', json.id);",
              "});",
              "pm.test('Response time is acceptable (below collection maxResponseTime)', function () {",
              "    var max = parseInt(pm.collectionVariables.get('maxResponseTime') || '2000', 10);",
              "    pm.expect(pm.response.responseTime).to.be.below(max);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Created Post",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts/{{createdId}}",
          "host": ["{{baseUrl}}"],
          "path": ["posts", "{{createdId}}"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Ensure we have a createdId from the POST",
              "pm.test('createdId is set', function () {",
              "    pm.expect(pm.environment.get('createdId')).to.not.be.undefined;",
              "});",
              "// Handle non-persistent APIs: if GET returns 200, validate body; if 404, mark as expected behavior for mock APIs",
              "if (pm.response.code === 200) {",
              "    pm.test('Status code is 200', function () {",
              "        pm.response.to.have.status(200);",
              "    });",
              "    pm.test('Returned post matches created id', function () {",
              "        var json = pm.response.json();",
              "        var createdId = parseInt(pm.environment.get('createdId'), 10);",
              "        pm.expect(json.id).to.eql(createdId);",
              "        pm.expect(json).to.have.property('title');",
              "    });",
              "} else if (pm.response.code === 404) {",
              "    pm.test('Get Created Post returned 404 — non-persistent API', function () {",
              "        pm.expect(pm.response.code).to.eql(404);",
              "    });",
              "} else {",
              "    pm.test('Unexpected status code for Get Created Post', function () {",
              "        pm.expect([200,404]).to.include(pm.response.code);",
              "    });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Collection-level safety checks",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has JSON content-type', function () {",
              "    pm.expect(pm.response.headers.get('content-type')).to.include('application/json');",
              "});",
              "pm.test('Has at least one item', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.length).to.be.above(0);",
              "});",
              "pm.test('Each item has id,title,body,userId with correct types', function () {",
              "    var json = pm.response.json();",
              "    json.forEach(function(item) {",
              "        pm.expect(item).to.have.property('id');",
              "        pm.expect(item.id).to.be.a('number');",
              "        pm.expect(item).to.have.property('title');",
              "        pm.expect(item.title).to.be.a('string');",
              "        pm.expect(item).to.have.property('body');",
              "        pm.expect(item.body).to.be.a('string');",
              "        pm.expect(item).to.have.property('userId');",
              "        pm.expect(item.userId).to.be.a('number');",
              "    });",
              "});",
              "pm.test('Response time is acceptable (below collection maxResponseTime)', function () {",
              "    var max = parseInt(pm.collectionVariables.get('maxResponseTime') || '2000', 10);",
              "    pm.expect(pm.response.responseTime).to.be.below(max);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://jsonplaceholder.typicode.com",
      "type": "string"
    },
    {
      "key": "maxResponseTime",
      "value": "2000",
      "type": "string"
    }
  ]
}
